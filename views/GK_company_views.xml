<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="t4_gate_keeper_company_view_list" model="ir.ui.view">
        <field name="name">t4.gate_keeper.company.view.list</field>
        <field name="model">res.company</field>
        <field name="arch" type="xml">
            <list string="Companies">
                <field name="name"/>
                <field name="parent_id"/>
            </list>
        </field>
    </record>

    <record id="t4_gate_keeper_company_view_form" model="ir.ui.view">
        <field name="name">t4.gate_keeper.company.view.form</field>
        <field name="model">res.company</field>
        <field name="arch" type="xml">
            <form string="Company">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="parent_id" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Controllers" name="controllers">
                            <field name="gate_keeper_controller_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="serial_number"/>
                                    <field name="last_heartbeat_at"/>
                                    <field name="last_sync_at"/>
                                    <field name="status"
                                           widget="badge"
                                           decoration-success="status == 'online'"
                                           decoration-danger="status == 'offline'"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="t4_gate_keeper_company_action" model="ir.actions.act_window">
        <field name="name">Companies</field>
        <field name="res_model">res.company</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('id', 'child_of', context.get('allowed_company_ids', []))]</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No company found!
            </p>
        </field>
    </record>

    <record id="t4_gate_keeper_company_action_view_list" model="ir.actions.act_window.view">
        <field name="sequence" eval="1"/>
        <field name="view_mode">list</field>
        <field name="view_id" ref="t4_gate_keeper_company_view_list"/>
        <field name="act_window_id" ref="t4_gate_keeper_company_action"/>
    </record>

    <record id="t4_gate_keeper_company_action_view_form" model="ir.actions.act_window.view">
        <field name="sequence" eval="2"/>
        <field name="view_mode">form</field>
        <field name="view_id" ref="t4_gate_keeper_company_view_form"/>
        <field name="act_window_id" ref="t4_gate_keeper_company_action"/>
    </record>
</odoo>