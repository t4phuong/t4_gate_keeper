<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Tree View -->
    <record id="t4_gate_keeper_attendance_log_view_list" model="ir.ui.view">
        <field name="name">t4.gate_keeper.attendance_log.view.list</field>
        <field name="model">t4.gate_keeper.attendance_log</field>
        <field name="arch" type="xml">
            <list default_order="access_time desc">
                <field name="employee_id"/>
                <field name="controller_id"/>
                <field name="device_id" optional="show"/>
                <field name="access_time"/>
                <field name="direction"/>
                <field name="verification_type" optional="show"/>
                <field name="sync_status" widget="badge" 
                       decoration-success="sync_status == 'success'" 
                       decoration-warning="sync_status == 'updating'" 
                       decoration-danger="sync_status == 'fail'"/>
                <field name="branch_id" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="t4_gate_keeper_attendance_log_view_form" model="ir.ui.view">
        <field name="name">t4.gate_keeper.attendance_log.view.form</field>
        <field name="model">t4.gate_keeper.attendance_log</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group string="Log Details">
                            <field name="employee_id"/>
                            <field name="access_time"/>
                            <field name="direction"/>
                            <field name="verification_type"/>
                            <field name="sync_status"/>
                        </group>
                        <group string="Hardware Information">
                            <field name="controller_id"/>
                            <field name="device_id"/>
                            <field name="branch_id"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="t4_gate_keeper_attendance_log_view_search" model="ir.ui.view">
        <field name="name">t4.gate_keeper.attendance_log.view.search</field>
        <field name="model">t4.gate_keeper.attendance_log</field>
        <field name="arch" type="xml">
            <search>
                <field name="employee_id"/>
                <field name="controller_id"/>
                <field name="device_id"/>
                <field name="access_time"/>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="t4_gate_keeper_attendance_log_action" model="ir.actions.act_window">
        <field name="name">Attendance Logs</field>
        <field name="res_model">t4.gate_keeper.attendance_log</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="t4_gate_keeper_attendance_log_view_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No attendance logs found.
            </p>
            <p>
                Attendance logs will appear here when pushed from the controllers.
            </p>
        </field>
    </record>

</odoo>
