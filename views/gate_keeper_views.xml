<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Controller Views -->
    <record id="t4_gate_keeper_controller_view_list" model="ir.ui.view">
        <field name="name">t4.gate_keeper.controller.view.list</field>
        <field name="model">t4.gate_keeper.controller</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="branch_id"/>
                <field name="last_heartbeat_at"/>
                <field name="last_sync_at"/>
                <field  name="status" 
                        widget="badge"
                        decoration-success="status == 'online'"
                        decoration-danger="status == 'offline'"/>
            </list>
        </field>
    </record>

    <record id="t4_gate_keeper_controller_view_form" model="ir.ui.view">
        <field name="name">t4.gate_keeper.controller.view.form</field>
        <field name="model">t4.gate_keeper.controller</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="serial_number"/>
                            <field name="branch_id"/>
                            <field name="connection_type"/>
                        </group>
                        <group>
                            <field name="status"/>
                            <field name="ip_address"/>
                            <field name="mac_address"/>
                            <field name="hardware_model"/>
                            <field name="firmware_version"/>
                        </group>
                        <group>
                            <field name="last_heartbeat_at" readonly="1"/>
                            <field name="last_sync_at" readonly="1"/>
                            <field name="installed_at"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Devices" name="devices">
                            <field name="device_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="device_model"/>
                                    <field name="device_role"/>
                                    <field name="serial_number"/>
                                    <field name="port_or_channel"/>
                                    <field name="status"
                                           widget="badge"
                                           decoration-success="status == 'active'"
                                           decoration-danger="status == 'faulty'"
                                           decoration-muted="status == 'disabled'"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="t4_gate_keeper_controller_action" model="ir.actions.act_window">
        <field name="name">Controllers</field>
        <field name="res_model">t4.gate_keeper.controller</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Device Views -->
    <record id="t4_gate_keeper_device_view_list" model="ir.ui.view">
        <field name="name">t4.gate_keeper.device.view.list</field>
        <field name="model">t4.gate_keeper.device</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="device_model"/>
                <field name="device_role"/>
                <field name="serial_number"/>
                <field name="controller_id"/>
                <field name="branch_id"/>
                <field name="last_seen_at"/>
                <field name="status"
                       widget="badge"
                       decoration-success="status == 'active'"
                       decoration-danger="status == 'faulty'"
                       decoration-muted="status == 'disabled'"/>
            </list>
        </field>
    </record>

    <record id="t4_gate_keeper_device_view_form" model="ir.ui.view">
        <field name="name">t4.gate_keeper.device.view.form</field>
        <field name="model">t4.gate_keeper.device</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="controller_id"/>
                            <field name="branch_id" readonly="1"/>
                            <field name="device_role"/>
                            <field name="status"/>
                        </group>
                        <group>
                            <field name="vendor"/>
                            <field name="device_model"/>
                            <field name="serial_number"/>
                            <field name="port_or_channel"/>
                            <field name="firmware_version"/>
                            <field name="system_version"/>
                        </group>
                        <group string="Audit">
                            <field name="last_seen_at" readonly="1"/>
                            <field name="installed_at"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Supported Algorithms" name="supported_algorithms">
                            <field name="algorithm_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="algorithm_type"/>
                                    <field name="version"/>
                                    <!-- <field name="vendor"/> -->
                                    <field name="template_format"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="t4_gate_keeper_device_action" model="ir.actions.act_window">
        <field name="name">Devices</field>
        <field name="res_model">t4.gate_keeper.device</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Algorithm Views -->
    <record id="t4_gate_keeper_algorithm_view_list" model="ir.ui.view">
        <field name="name">t4.gate_keeper.algorithm.view.list</field>
        <field name="model">t4.gate_keeper.algorithm</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="algorithm_type"/>
                <field name="version"/>
                <!-- <field name="vendor"/> -->
                <field name="template_format"/>
            </list>
        </field>
    </record>

    <record id="t4_gate_keeper_algorithm_view_form" model="ir.ui.view">
        <field name="name">t4.gate_keeper.algorithm.view.form</field>
        <field name="model">t4.gate_keeper.algorithm</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group string="Algorithm">
                            <field name="name"/>
                            <field name="algorithm_type"/>
                            <field name="version"/>
                        </group>
                        <group string="Compatibility">
                            <!-- <field name="vendor"/> -->
                            <field name="template_format"/>
                        </group>
                    </group>
                    <group>
                        <field name="notes"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="t4_gate_keeper_algorithm_action" model="ir.actions.act_window">
        <field name="name">Algorithms</field>
        <field name="res_model">t4.gate_keeper.algorithm</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
