<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- List View -->
    <record id="view_employee_biometric_list" model="ir.ui.view">
        <field name="name">t4.gate_keeper.employee.biometric.list</field>
        <field name="model">t4.gate_keeper.employee.biometric</field>
        <field name="arch" type="xml">
            <list>
                <field name="employee_id"/>
                <field name="algorithm_id"/>
                <field name="biometric_type"/>
                <field name="finger_index"/>
                <field name="description"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_employee_biometric_form" model="ir.ui.view">
        <field name="name">t4.gate_keeper.employee.biometric.form</field>
        <field name="model">t4.gate_keeper.employee.biometric</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="employee_id"/>
                            <field name="algorithm_id"/>
                            <field name="biometric_type"/>
                            <field name="finger_index"/>
                        </group>
                        <group>
                            <field name="template"/>
                            <field name="description"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_employee_biometric" model="ir.actions.act_window">
        <field name="name">Employee Biometrics</field>
        <field name="res_model">t4.gate_keeper.employee.biometric</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
