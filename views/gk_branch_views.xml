<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="t4_gate_keeper_branch_view_list" model="ir.ui.view">
        <field name="name">t4.gate_keeper.branch.view.list</field>
        <field name="model">t4.gate_keeper.branch</field>
        <field name="arch" type="xml">
            <list string="Branches">
                <field name="name"/>
                <field name="code"/>
                <field name="company_id"/>
            </list>
        </field>
    </record>

    <record id="t4_gate_keeper_branch_view_form" model="ir.ui.view">
        <field name="name">t4.gate_keeper.branch.view.form</field>
        <field name="model">t4.gate_keeper.branch</field>
        <field name="arch" type="xml">
            <form string="Branch">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                        </group>
                        <group>
                            <field name="company_id"/>
                            <field name="address"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Controllers" name="controllers">
                            <field name="controller_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="serial_number"/>
                                    <field name="last_heartbeat_at"/>
                                    <field name="last_sync_at"/>
                                    <field name="status"
                                           widget="badge"
                                           decoration-success="status == 'online'"
                                           decoration-danger="status == 'offline'"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="t4_gate_keeper_branch_action" model="ir.actions.act_window">
        <field name="name">Branches</field>
        <field name="res_model">t4.gate_keeper.branch</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No branch found! Create your first branch.
            </p>
        </field>
    </record>
</odoo>
