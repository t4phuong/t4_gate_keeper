<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Tree View -->
    <record id="t4_gate_keeper_device_model_view_list" model="ir.ui.view">
        <field name="name">t4.gate_keeper.device_model.view.list</field>
        <field name="model">t4.gate_keeper.device_model</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="algorithm_ids" widget="many2many_tags"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="t4_gate_keeper_device_model_view_form" model="ir.ui.view">
        <field name="name">t4.gate_keeper.device_model.view.form</field>
        <field name="model">t4.gate_keeper.device_model</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="algorithm_ids" widget="many2many_tags"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="t4_gate_keeper_device_model_view_search" model="ir.ui.view">
        <field name="name">t4.gate_keeper.device_model.view.search</field>
        <field name="model">t4.gate_keeper.device_model</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="algorithm_ids"/>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="t4_gate_keeper_device_model_action" model="ir.actions.act_window">
        <field name="name">Device Models</field>
        <field name="res_model">t4.gate_keeper.device_model</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="t4_gate_keeper_device_model_view_search"/>
    </record>

</odoo>
