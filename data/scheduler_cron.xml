<odoo>

    <record id="ir_cron_controller_status" model="ir.cron">
        <field name="name">Update Hardware Status</field>
        <field name="model_id" ref="model_t4_gate_keeper_scheduler"/>
        <field name="state">code</field>
        <field name="code">model.cron_update_hardware_status()</field>

        <field name="interval_number">1</field>
        <field name="interval_type">minutes</field>

        <field name="active">True</field>
    </record>

    <record id="ir_cron_sync_missing_employees" model="ir.cron">
        <field name="name">Sync Missing Employees to Gate Keeper</field>
        <field name="model_id" ref="model_t4_gate_keeper_scheduler"/>
        <field name="state">code</field>
        <field name="code">model.cron_sync_missing_employees()</field>
        <field name="interval_number">12</field>
        <field name="interval_type">hours</field>
        <field name="active">True</field>
    </record>

</odoo>