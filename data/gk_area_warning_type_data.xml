<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="warning_type_outside_hours" model="t4.gate_keeper.area_warning_type">
            <field name="name">Outside Working Hours</field>
            <field name="code">outside_hours</field>
            <field name="description">Access occurred outside standard branch working hours or on weekends.</field>
        </record>

        <record id="warning_type_unauthorized" model="t4.gate_keeper.area_warning_type">
            <field name="name">Unauthorized Access</field>
            <field name="code">unauthorized</field>
            <field name="description">Access attempted by an employee without correct clearance for this area.</field>
        </record>

        <record id="warning_type_offline" model="t4.gate_keeper.area_warning_type">
            <field name="name">Device Offline</field>
            <field name="code">offline</field>
            <field name="description">The physical access control device has lost connection to the controller.</field>
        </record>

        <record id="warning_type_tamper" model="t4.gate_keeper.area_warning_type">
            <field name="name">Tamper / Forced Entry</field>
            <field name="code">tamper</field>
            <field name="description">Physical tamper switch triggered or door forced open without credential authorization.</field>
        </record>
    </data>
</odoo>
